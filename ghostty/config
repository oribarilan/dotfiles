# in ~/.config/ghostty/config add:
# config-file = "/absolute/path/to/this/file"

# reload config with cmd + shift + ,

theme = Catppuccin Mocha

keybind = cmd+/=new_split:right
keybind = cmd+\=new_split:down

confirm-close-surface = false

macos-option-as-alt = true

font-family = "Fira Code Mono"

# invert fg/bg of the cell under the cursor
cursor-color = #5fd7ff
cursor-text  = #000000

# shaders from https://github.com/KroneCorylus/ghostty-shader-playground/tree/main/shaders
custom-shader = "~/.config/dotfiles/ghostty/shaders/cursor_smear_fade.glsl"

window-colorspace = display-p3
alpha-blending = linear-corrected

# Quick terminal (drop-down). Hyper+g = ctrl+opt+cmd+g
keybind = global:ctrl+alt+cmd+g=toggle_quick_terminal
quick-terminal-position = top
quick-terminal-screen = main
quick-terminal-animation-duration = 0.2
