{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/claude-opus-4.6",
  "share": "disabled",
  "lsp": {
    "pyright": {
      "command": [
        "npx",
        "-y",
        "-p",
        "pyright",
        "pyright-langserver",
        "--stdio"
      ],
      "extensions": [
        ".py",
        ".pyi"
      ],
      "env": {
        "PYTHONPATH": "src"
      }
    }
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ],
      "enabled": false
    }
  },
  "plugin": [
    "oh-my-opencode-slim"
  ]
}
